<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      Control de márgenes en PDF para olas/lotes.

      Nota importante:
      En instalaciones con wkhtmltopdf "unpatched qt" Odoo NO puede usar
      header-html/footer-html (ver warning en logs), por lo que la paginación X/Y
      basada en span.page/topage en header/footer no es fiable.
    -->

    <record id="nakel_picking_batch_paperformat" model="report.paperformat">
        <field name="name">Nakel - Picking Batch (compact)</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- Enlazar el paperformat al reporte estándar de stock_picking_batch -->
    <record id="stock_picking_batch.action_report_picking_batch" model="ir.actions.report">
        <field name="paperformat_id" ref="nakel_picking_batch_paperformat"/>
    </record>
</odoo>


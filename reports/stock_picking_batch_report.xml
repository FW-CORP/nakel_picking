<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Override the standard Batch Picking report template
        to show consolidated quantities instead of individual lines
    -->

    <!-- Replace the main report template -->
    <template id="report_picking_batch" inherit_id="stock_picking_batch.report_picking_batch" name="Batch Picking Consolidated Report">
        <!-- Replace the entire document body -->
        <xpath expr="//t[@t-call='web.html_container']" position="replace">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="batch">
                    <!-- Layout NO factura: `web.basic_layout` (evita header corporativo de external_layout) -->
                    <t t-call="web.basic_layout">
                        <style>
                            /*
                             * PDF (wkhtmltopdf / WebKit): page-break-inside: avoid en &lt;tr&gt; suele ignorarse.
                             * Solución: cada fila lógica va en una tabla de una sola fila (.nakel-batch-pdf-row).
                             */
                            .nakel-batch-pdf-row {
                                page-break-inside: avoid !important;
                                break-inside: avoid !important;
                                width: 100%;
                                table-layout: fixed;
                                border-collapse: collapse;
                            }
                            .nakel-batch-pdf-row td,
                            .nakel-batch-pdf-row th {
                                vertical-align: middle;
                            }
                            /* Encabezado de tabla suelta (solo columnas): sin salto raro */
                            .nakel-batch-pdf-head {
                                width: 100%;
                                table-layout: fixed;
                                border-collapse: collapse;
                                margin-bottom: 0 !important;
                            }
                            /* Barra de ruta: intentar no dejarla sola al pie de página */
                            .nakel-route-section .nakel-route-header {
                                page-break-after: avoid;
                                break-after: avoid-page;
                            }

                            /* `basic_layout` a veces deja padding arriba en article */
                            article.o_report_layout_standard,
                            .o_report_layout_standard,
                            .page {
                                margin-top: 0 !important;
                                padding-top: 0 !important;
                            }

                            /* Footer: referencia de ola (wave) + paginación (si se mezclan hojas de distintos lotes) */
                            .footer.nakel-footer {
                                border-top: 1px solid #e6e6e6;
                                color: #555;
                                font-size: 9px;
                                padding-top: 2mm;
                                display: flex;
                                justify-content: space-between;
                                align-items: baseline;
                                flex-wrap: wrap;
                                gap: 4px 10px;
                            }
                            .footer.nakel-footer .nakel-footer-wave {
                                text-align: left;
                                font-weight: 600;
                                color: #333;
                                min-width: 0;
                                flex: 1 1 auto;
                            }
                            .footer.nakel-footer .nakel-footer-wave .nakel-footer-wave-label {
                                font-weight: 500;
                                color: #666;
                                margin-right: 4px;
                            }
                            .footer.nakel-footer .nakel-footer-page {
                                white-space: nowrap;
                                flex: 0 0 auto;
                                margin-left: auto;
                                text-align: right;
                            }

                            /* PLU = imagen Code128 escaneable (no solo texto) */
                            .nakel-consolidated-plu {
                                padding: 5px 4px !important;
                                vertical-align: middle !important;
                            }
                            .nakel-consolidated-plu .nakel-consolidated-plu-barcode {
                                max-width: 100%;
                                height: 52px;
                                object-fit: contain;
                                display: block;
                                margin: 0 auto;
                            }
                            .nakel-consolidated-plu .nakel-consolidated-plu-empty {
                                font-size: 11pt;
                                font-weight: 400;
                                color: #888;
                            }
                        </style>

                        <div class="footer nakel-footer">
                            <span class="nakel-footer-wave">
                                <span class="nakel-footer-wave-label">Wave</span>
                                <span t-field="batch.name"/>
                            </span>
                            <span class="nakel-footer-page">
                                Página <span class="page"/>/<span class="topage"/>
                            </span>
                        </div>

                        <div class="page nakel-batch-report">
                            <!-- Logo y nombre empresa (primera hoja) -->
                            <div class="row mb-2" style="border-bottom: 1px solid #ddd; padding-bottom: 6px;">
                                <div class="col-8">
                                    <t t-set="company" t-value="batch.company_id or (batch.picking_ids[:1].company_id if batch.picking_ids else None)"/>
                                    <t t-if="company and company.logo">
                                        <img t-att-src="image_data_uri(company.logo)" style="max-height: 55px; vertical-align: middle;" alt="Logo"/>
                                    </t>
                                    <span t-if="company" t-esc="company.name" style="font-size: 1.3em; font-weight: bold; margin-left: 12px; vertical-align: middle;"/>
                                </div>
                                <div class="col-4 text-end"/>
                            </div>
                            <!-- Header -->
                            <div class="row">
                                <div class="col-8">
                                    <h2>
                                        <span>Resumen: </span>
                                        <span t-field="batch.name"/>
                                    </h2>
                                </div>
                                <div class="col-4 text-end">
                                    <t t-if="batch.name">
                                        <img t-att-src="batch._generate_barcode_image(batch.name, 'Code128', 400, 60)" style="max-width:100%;height:40px;object-fit:contain;" alt="Barcode"/>
                                    </t>
                                </div>
                            </div>

                            <!-- Batch Info -->
                            <div class="row mt-1 mb-2">
                                <div class="col-6">
                                    <strong>Responsable:</strong>
                                    <span t-field="batch.user_id"/>
                                </div>
                                <div class="col-6">
                                    <strong>Estado:</strong>
                                    <span t-field="batch.state"/>
                                </div>
                            </div>

                            <!-- Pickings: una tabla por fila (evita cortes a mitad de fila en PDF / wkhtmltopdf) -->
                            <h4 class="mt-4 mb-2">Traslados en el Lote</h4>
                            <table class="table table-sm table-bordered nakel-batch-pdf-head">
                                <colgroup>
                                    <col style="width: 10%;"/>
                                    <col style="width: 30%;"/>
                                    <col style="width: 30%;"/>
                                    <col style="width: 15%;"/>
                                    <col style="width: 15%;"/>
                                </colgroup>
                                <thead>
                                    <tr style="background-color: #f8f9fa;">
                                        <th>Secuencia</th>
                                        <th>Trasladar</th>
                                        <th>Código de barras</th>
                                        <th>Estado</th>
                                        <th>Fecha programada</th>
                                    </tr>
                                </thead>
                            </table>
                            <t t-foreach="batch.picking_ids" t-as="picking">
                                <table class="table table-sm table-bordered nakel-batch-pdf-row" style="margin-top: -1px;">
                                    <colgroup>
                                        <col style="width: 10%;"/>
                                        <col style="width: 30%;"/>
                                        <col style="width: 30%;"/>
                                        <col style="width: 15%;"/>
                                        <col style="width: 15%;"/>
                                    </colgroup>
                                    <tbody>
                                        <tr>
                                            <td><span t-esc="picking_index + 1"/></td>
                                            <td><span t-field="picking.name"/></td>
                                            <td>
                                                <t t-if="picking.name">
                                                    <img t-att-src="batch._generate_barcode_image(picking.name, 'Code128', 400, 60)" style="max-width:100%;height:35px;object-fit:contain;" alt="Barcode"/>
                                                </t>
                                            </td>
                                            <td><span t-field="picking.state"/></td>
                                            <td><span t-field="picking.scheduled_date" t-options='{"widget": "datetime"}'/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </t>

                            <div style="page-break-before: always;"/>

                            <!-- Consolidated Products Section -->
                            <h3 class="mt-4 mb-3">Productos Consolidados</h3>

                            <t t-set="consolidated_lines" t-value="batch._get_consolidated_lines()"/>

                            <!-- Group by location route -->
                            <t t-set="grouped_by_route" t-value="{}"/>
                            <t t-foreach="consolidated_lines" t-as="line">
                                <t t-set="route_key" t-value="'DESDE %s\nA %s' % (line['location_name'], line['location_dest_name'])"/>
                                <t t-if="route_key not in grouped_by_route" t-set="grouped_by_route" t-value="{**grouped_by_route, route_key: []}"/>
                                <t t-set="dummy" t-value="grouped_by_route[route_key].append(line)"/>
                            </t>

                            <t t-foreach="grouped_by_route.items()" t-as="route_item">
                                <t t-set="route_label" t-value="route_item[0]"/>
                                <t t-set="route_lines" t-value="route_item[1]"/>

                                <!-- Ruta: cabecera gris + tabla de productos (una tabla por fila, mismo criterio PDF que pickings) -->
                                <div class="mt-4 nakel-route-section">
                                    <div class="nakel-route-header" style="background-color: #e9ecef; padding: 8px; margin-bottom: 10px;">
                                        <strong style="white-space: pre-line;" t-esc="route_label"/>
                                    </div>

                                    <table class="table table-sm table-bordered nakel-batch-pdf-head">
                                    <colgroup>
                                        <col style="width: 36%;"/>
                                        <col style="width: 14%;"/>
                                        <col style="width: 30%;"/>
                                        <col style="width: 20%;"/>
                                    </colgroup>
                                    <thead style="background-color: #f8f9fa;">
                                        <tr>
                                            <th>Producto</th>
                                            <th>Cantidad</th>
                                            <th>PLU</th>
                                            <th>TOTAL</th>
                                        </tr>
                                    </thead>
                                    </table>
                                    <!-- Agrupación por categoría (las líneas ya vienen ordenadas por categ_name) -->
                                    <t t-set="prev_categ" t-value="''"/>
                                    <t t-foreach="route_lines" t-as="line">
                                        <t t-set="line_categ" t-value="(line.get('categ_name') or 'SIN CATEGORÍA')"/>
                                        <t t-if="line_categ != prev_categ">
                                            <t t-set="prev_categ" t-value="line_categ"/>
                                            <table class="table table-sm table-bordered nakel-batch-pdf-row" style="margin-top: -1px;">
                                                <colgroup>
                                                    <col style="width: 100%;"/>
                                                </colgroup>
                                                <tbody>
                                                    <tr style="background-color:#f2f4f7;">
                                                        <td style="font-weight:700;">
                                                            <span t-esc="line_categ"/>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </t>
                                        <table class="table table-sm table-bordered nakel-batch-pdf-row" style="margin-top: -1px;">
                                            <colgroup>
                                                <col style="width: 36%;"/>
                                                <col style="width: 14%;"/>
                                                <col style="width: 30%;"/>
                                                <col style="width: 20%;"/>
                                            </colgroup>
                                            <tbody>
                                                <tr>
                                                    <td>
                                                        <span t-esc="line['product_name']"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <strong t-esc="'%.2f' % line['quantity']"/>
                                                        <span t-esc="line['uom_name']"/>
                                                    </td>
                                                    <td class="nakel-consolidated-plu text-center">
                                                        <t t-set="plu_val" t-value="(line.get('product_plu') or line.get('product_code') or '').strip()"/>
                                                        <t t-if="plu_val">
                                                            <img class="nakel-consolidated-plu-barcode"
                                                                 t-att-src="batch._generate_barcode_image(plu_val, 'Code128', 420, 72)"
                                                                 alt="Código de barras PLU"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="nakel-consolidated-plu-empty">—</span>
                                                        </t>
                                                    </td>
                                                    <td class="text-center">
                                                        <span t-esc="batch._format_total_display_for_line(line)"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </t>
                                </div>
                            </t>

                            <div style="page-break-before: always;"/>

                            <!-- RESUMEN DE COBRANZA (transportista) -->
                            <h3 class="mt-4 mb-3">RESUMEN DE COBRANZA</h3>
                            <!-- Importante: evitar depender de métodos Python nuevos en QWeb.
                                 Calculamos totales en QWeb a partir de `batch._get_valuation_lines()`. -->
                            <t t-set="valuation_lines" t-value="batch._get_valuation_lines()"/>
                            <t t-if="valuation_lines">
                                <table class="table table-sm table-bordered">
                                    <colgroup>
                                        <col style="width: 12%;"/>
                                        <col style="width: 28%;"/>
                                        <col style="width: 12%;"/>
                                        <col style="width: 16%;"/>
                                        <col style="width: 16%;"/>
                                        <col style="width: 16%;"/>
                                    </colgroup>
                                    <thead style="background-color: #f8f9fa;">
                                        <tr>
                                            <th>PICK</th>
                                            <th>Cliente</th>
                                            <th>SO</th>
                                            <th class="text-end">Total SO</th>
                                            <th>Factura</th>
                                            <th class="text-end">Total Factura</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="valuation_lines" t-as="vl">
                                            <tr>
                                                <td>
                                                    <span t-esc="vl.get('picking_short') or (vl.get('picking').name if vl.get('picking') else '')"/>
                                                </td>
                                                <td>
                                                    <span t-esc="vl.get('partner_name') or '-'"/>
                                                </td>
                                                <td>
                                                    <span t-esc="vl.get('sale_name') or '-'"/>
                                                </td>
                                                <td class="text-end">
                                                    <t t-if="vl.get('sale_currency')">
                                                        <span t-esc="vl.get('sale_total')"
                                                              t-options='{"widget": "monetary", "display_currency": vl.get("sale_currency")}'/>
                                                    </t>
                                                    <t t-else="">
                                                        <span style="color:#777;">-</span>
                                                    </t>
                                                </td>
                                                <td>
                                                    <t t-if="vl.get('has_invoice')">
                                                        <span t-esc="vl.get('invoice_name') or '-'"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span style="color:#777;">Sin factura</span>
                                                    </t>
                                                </td>
                                                <td class="text-end">
                                                    <t t-if="vl.get('has_invoice') and vl.get('currency')">
                                                        <span t-esc="vl.get('amount_total')"
                                                              t-options='{"widget": "monetary", "display_currency": vl.get("currency")}'/>
                                                    </t>
                                                    <t t-else="">
                                                        <span style="color:#777;">-</span>
                                                    </t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>

                                <!-- Totales -->
                                <t t-set="cur" t-value="(valuation_lines and (valuation_lines[0].get('sale_currency') or valuation_lines[0].get('currency'))) or None"/>
                                <t t-set="sale_seen" t-value="{}"/>
                                <t t-set="inv_seen" t-value="{}"/>
                                <t t-set="sum_sale" t-value="0.0"/>
                                <t t-set="sum_inv" t-value="0.0"/>
                                <t t-set="sum_refund" t-value="0.0"/>
                                <t t-set="term_totals" t-value="{}"/>
                                <t t-foreach="valuation_lines" t-as="vl_sum">
                                    <!-- SO únicas -->
                                    <t t-set="so_key" t-value="vl_sum.get('sale_name') or ''"/>
                                    <t t-if="so_key and so_key not in sale_seen">
                                        <t t-set="sale_seen" t-value="{**sale_seen, so_key: True}"/>
                                        <t t-set="sum_sale" t-value="sum_sale + float(vl_sum.get('sale_total') or 0.0)"/>
                                        <t t-set="term_label" t-value="(vl_sum.get('payment_term') or '').strip() or 'CONTADO'"/>
                                        <t t-set="term_totals" t-value="{**term_totals, term_label: float(term_totals.get(term_label) or 0.0) + float(vl_sum.get('sale_total') or 0.0)}"/>
                                    </t>
                                    <!-- Facturas / NC -->
                                    <t t-if="vl_sum.get('has_invoice')">
                                        <t t-set="inv" t-value="vl_sum.get('invoice')"/>
                                        <t t-set="inv_id" t-value="(inv.id if inv else 0)"/>
                                        <t t-if="inv_id and inv_id not in inv_seen">
                                            <t t-set="inv_seen" t-value="{**inv_seen, inv_id: True}"/>
                                            <t t-set="mt" t-value="(inv.move_type if inv else '')"/>
                                            <t t-if="mt == 'out_refund'">
                                                <t t-set="sum_refund" t-value="sum_refund + float(vl_sum.get('amount_total') or 0.0)"/>
                                            </t>
                                            <t t-else="">
                                                <t t-set="sum_inv" t-value="sum_inv + float(vl_sum.get('amount_total') or 0.0)"/>
                                            </t>
                                        </t>
                                    </t>
                                </t>
                                <table class="table table-sm table-bordered" style="margin-top: 10px;">
                                    <colgroup>
                                        <col style="width: 60%;"/>
                                        <col style="width: 40%;"/>
                                    </colgroup>
                                    <tbody>
                                        <tr style="background-color:#f8f9fa;">
                                            <td style="font-weight:700;">TOTAL SO (suma)</td>
                                            <td class="text-end" style="font-weight:700;">
                                                <t t-if="cur">
                                                    <span t-esc="sum_sale"
                                                          t-options='{"widget": "monetary", "display_currency": cur}'/>
                                                </t>
                                                <t t-else="">-</t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>TOTAL FACTURAS</td>
                                            <td class="text-end">
                                                <t t-if="cur">
                                                    <span t-esc="sum_inv"
                                                          t-options='{"widget": "monetary", "display_currency": cur}'/>
                                                </t>
                                                <t t-else="">-</t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>TOTAL NOTAS DE CRÉDITO</td>
                                            <td class="text-end">
                                                <t t-if="cur">
                                                    <span t-esc="sum_refund"
                                                          t-options='{"widget": "monetary", "display_currency": cur}'/>
                                                </t>
                                                <t t-else="">-</t>
                                            </td>
                                        </tr>
                                        <tr style="background-color:#f2f4f7;">
                                            <td style="font-weight:700;">NETO (Facturas + NC)</td>
                                            <td class="text-end" style="font-weight:700;">
                                                <t t-if="cur">
                                                    <span t-esc="sum_inv + sum_refund"
                                                          t-options='{"widget": "monetary", "display_currency": cur}'/>
                                                </t>
                                                <t t-else="">-</t>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>

                                <!-- Detalle por condición de venta -->
                                <t t-if="term_totals">
                                    <div style="margin-top: 10px; font-weight:700;">Detalle por condición de venta</div>
                                    <table class="table table-sm table-bordered">
                                        <colgroup>
                                            <col style="width: 70%;"/>
                                            <col style="width: 30%;"/>
                                        </colgroup>
                                        <thead style="background-color:#f8f9fa;">
                                            <tr>
                                                <th>Condición</th>
                                                <th class="text-end">Total SO</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="sorted(term_totals.items())" t-as="tt">
                                                <tr>
                                                    <td><span t-esc="tt[0]"/></td>
                                                    <td class="text-end">
                                                        <t t-if="cur">
                                                            <span t-esc="tt[1]"
                                                                  t-options='{"widget": "monetary", "display_currency": cur}'/>
                                                        </t>
                                                        <t t-else="">-</t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>

                            </t>
                            <t t-else="">
                                <div style="color:#777;">Sin picks en esta ola.</div>
                            </t>

                        </div>
                    </t>
                </t>
            </t>
        </xpath>
    </template>

</odoo>
